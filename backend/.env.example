# Backend Environment Variables
# Copy this file to .env for local development or set in Railway dashboard

# Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Google OAuth (Google Identity Services)
# Backend uses this to verify Google ID tokens
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Frontend uses this to render the Google Sign-In button (Vite)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# CORS - Add your frontend URLs
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Environment
ENVIRONMENT=production

# Python Path (for Railway)
PYTHONPATH=/app

# Port (Railway will set this automatically)
PORT=8000

# Email Configuration (for password reset)
# SMTP Server settings - Use Gmail or other email service
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords

# Frontend URL (for reset password link)
FRONTEND_URL=http://localhost:5173

# Optional: Cloud Storage
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
